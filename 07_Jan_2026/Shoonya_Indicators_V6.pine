//@version=6
indicator("Shoonya Strategy Indicators [V6]", overlay = true, max_lines_count = 500, max_labels_count = 500, max_bars_back = 500)

// ============================================================
// 1. INPUTS
// ============================================================

grp_zones = "Trading Zones (UT Bot + Trend Magic + KC)"
ut_a = input.int(2, "UT Bot Key Value (a)", group = grp_zones)
ut_c = input.int(1, "UT Bot ATR Period (c)", group = grp_zones)
tm_period = input.int(20, "Trend Magic ATR Period", group = grp_zones)
kc_len = input.int(20, "Keltner Length", group = grp_zones)
kc_mult = input.float(2.0, "Keltner Multiplier", group = grp_zones)
kc_atr_len = input.int(10, "Keltner ATR Length", group = grp_zones)

grp_div = "Divergence (RSI)"
rsi_len = input.int(21, "RSI Length", group = grp_div)
piv_lb_l = input.int(3, "Pivot Lookback Left", group = grp_div)
piv_lb_r = input.int(3, "Pivot Lookback Right", group = grp_div)
div_max_lb = input.int(60, "Max Lookback Bars", group = grp_div)
show_div = input.bool(true, "Show Divergences", group = grp_div)

grp_slope = "Slope Indicator"
slope_src_type = input.string("ZLEMA", "Slope Source Type", options = ["Close", "ZLEMA", "HMA", "McGinley"], group = grp_slope)
slope_period = input.int(5, "Slope Period", group = grp_slope)
zlema_len = input.int(14, "ZLEMA Length (for Source)", group = grp_slope)
hma_len = input.int(14, "HMA Length (for Source)", group = grp_slope)

// ============================================================
// 2. HELPER FUNCTIONS
// ============================================================

// --- Zero-Lag EMA (ZLEMA) ---
// Python: ema_input = series + (series - series.shift(lag)); return ema(ema_input, period)
f_zlema(src, len) =>
    lag = math.floor((len - 1) / 2)
    ema_data = src + (src - src[lag])
    ta.ema(ema_data, len)

// --- Hull Moving Average (HMA) ---
// Python: 2*wma(n/2) - wma(n); wma(sqrt(n))
f_hma(src, len) =>
    ta.wma(2 * ta.wma(src, int(len / 2)) - ta.wma(src, len), int(math.sqrt(len)))

// --- McGinley Dynamic ---
// Approximation in Pine
f_mcginley(src, len) =>
    mg = 0.0
    mg := na(mg[1]) ? src : mg[1] + (src - mg[1]) / (len * math.pow(src/mg[1], 4))
    mg

// --- Slope (Linear Regression Slope) ---
// Python: OLS slope of last N bars
f_slope(src, len) =>
    // Implementation of OLS Slope
    // Slope = (len * sum_xy - sum_x * sum_y) / (len * sum_xx - sum_x * sum_x)
    // We treat x as the physical index 0 to len-1
    // But since Pine series usually works backwards:
    // Let's use x = 0 (current) to len-1 (past).
    // Slope w.r.t time (future direction) is negative of slope w.r.t index.
    // Calculations:
    sum_x = 0.0
    sum_y = 0.0
    sum_xy = 0.0
    sum_xx = 0.0
    
    // We iterate 0 to len-1
    for i = 0 to len - 1
        val = src[i]
        // Let x be the chronological index.
        // Current bar is at x = len-1 ? No.
        // Oldest bar is at x = 0.
        // Current bar is at x = len-1.
        x = (len - 1) - i 
        
        sum_x += x
        sum_y += val
        sum_xy += x * val
        sum_xx += x * x
        
    slope = (len * sum_xy - sum_x * sum_y) / (len * sum_xx - sum_x * sum_x)
    slope

// ============================================================
// 3. INDICATOR LOGIC
// ============================================================

// --- 3.1 ZONES Logic ---

// UT Bot
ut_atr = ta.atr(ut_c) 
ut_nLoss = ut_a * ut_atr
var float ut_stop = 0.0
var int ut_pos = 0

// UT Bot Loop
ut_src = close
ut_prev_stop = nz(ut_stop[1], ut_src - ut_nLoss)

// Logic to emulate Python loop behavior
ut_stop_temp = 0.0
if (ut_src > ut_prev_stop and ut_src[1] > ut_prev_stop)
    ut_stop_temp := math.max(ut_prev_stop, ut_src - ut_nLoss)
else if (ut_src < ut_prev_stop and ut_src[1] < ut_prev_stop)
    ut_stop_temp := math.min(ut_prev_stop, ut_src + ut_nLoss)
else 
    ut_stop_temp := (ut_src > ut_prev_stop ? ut_src - ut_nLoss : ut_src + ut_nLoss)

ut_stop := ut_stop_temp

ut_pos_temp = 0
if (ut_src[1] < ut_stop[1] and ut_src > ut_stop[1])
    ut_pos_temp := 1 // Buy
else if (ut_src[1] > ut_stop[1] and ut_src < ut_stop[1])
    ut_pos_temp := -1 // Sell
else
    ut_pos_temp := nz(ut_pos[1], 1)

ut_pos := ut_pos_temp

// Trend Magic
// Python: atr = tr.rolling(period).mean() -> SMA
tm_atr = ta.sma(ta.tr, tm_period) 
var float tm_trend = 0.0
var int tm_dir = 1

tm_prev_trend = nz(tm_trend[1], close)
if (close > tm_prev_trend)
    tm_trend := math.max(tm_prev_trend, low - tm_atr)
    tm_dir := 1
else if (close < tm_prev_trend)
    tm_trend := math.min(tm_prev_trend, high + tm_atr)
    tm_dir := -1
else
    tm_trend := tm_prev_trend
    tm_dir := nz(tm_dir[1], 1)

// Keltner Channels
kc_basis_val = ta.ema(close, kc_len)
kc_range_val = ta.rma(ta.tr, kc_atr_len)
kc_upper = kc_basis_val + kc_range_val * kc_mult
kc_lower = kc_basis_val - kc_range_val * kc_mult

// Define Zones
is_buy_zone = (ut_pos == 1) and (tm_dir == 1) and (close > kc_basis_val)
is_sell_zone = (ut_pos == -1) and (tm_dir == -1) and (close < kc_basis_val)

// --- 3.2 DIVERGENCE Logic ---
rsi_val = ta.rsi(close, rsi_len)

// Pivots
ph = ta.pivothigh(rsi_val, piv_lb_l, piv_lb_r)
pl = ta.pivotlow(rsi_val, piv_lb_l, piv_lb_r)

// Arrays to store history
var ph_indices = array.new_int(0)
var ph_prices  = array.new_float(0)
var ph_rsis    = array.new_float(0)

var pl_indices = array.new_int(0)
var pl_prices  = array.new_float(0)
var pl_rsis    = array.new_float(0)

// Clean old pivots
if array.size(ph_indices) > 0
    if (bar_index - array.get(ph_indices, 0)) > (div_max_lb * 3)
        array.shift(ph_indices)
        array.shift(ph_prices)
        array.shift(ph_rsis)

if array.size(pl_indices) > 0
    if (bar_index - array.get(pl_indices, 0)) > (div_max_lb * 3)
        array.shift(pl_indices)
        array.shift(pl_prices)
        array.shift(pl_rsis)

if not na(ph)
    p_index = bar_index - piv_lb_r
    p_price = high[piv_lb_r]
    p_rsi   = rsi_val[piv_lb_r]
    array.push(ph_indices, p_index)
    array.push(ph_prices, p_price)
    array.push(ph_rsis, p_rsi)

if not na(pl)
    p_index = bar_index - piv_lb_r
    p_price = low[piv_lb_r]
    p_rsi   = rsi_val[piv_lb_r]
    array.push(pl_indices, p_index)
    array.push(pl_prices, p_price)
    array.push(pl_rsis, p_rsi)

bool bull_div = false
bool bear_div = false

// Check Bearish
if not na(ph) and array.size(ph_indices) > 1 and show_div
    size = array.size(ph_indices)
    curr_price = array.get(ph_prices, size-1)
    curr_rsi   = array.get(ph_rsis, size-1)
    curr_idx   = array.get(ph_indices, size-1)
    
    // Check against ALL previous pivots in lookback
    // Wait, simple loop is fine.
    for i = size - 2 to 0
        prev_idx = array.get(ph_indices, i)
        if (curr_idx - prev_idx <= div_max_lb)
            prev_price = array.get(ph_prices, i)
            prev_rsi   = array.get(ph_rsis, i)
            if (curr_price > prev_price and curr_rsi < prev_rsi)
                bear_div := true
                break
        else 
            // Since arrays are ordered, if we hit one too old, older ones are too old.
            // But we iterate backwards from new (size-2). 
            // So if size-2 is within range, check. 
            // If size-2 is out of range, then all i < size-2 are out of range.
            break 

// Check Bullish
if not na(pl) and array.size(pl_indices) > 1 and show_div
    size = array.size(pl_indices)
    curr_price = array.get(pl_prices, size-1)
    curr_rsi   = array.get(pl_rsis, size-1)
    curr_idx   = array.get(pl_indices, size-1)
    
    for i = size - 2 to 0
        prev_idx = array.get(pl_indices, i)
        if (curr_idx - prev_idx <= div_max_lb)
            prev_price = array.get(pl_prices, i)
            prev_rsi   = array.get(pl_rsis, i)
            if (curr_price < prev_price and curr_rsi > prev_rsi)
                bull_div := true
                break
        else
            break

// --- 3.3 SLOPE Logic ---
slope_src = switch slope_src_type
    "Close" => close
    "ZLEMA" => f_zlema(close, zlema_len)
    "HMA" => f_hma(close, hma_len)
    "McGinley" => f_mcginley(close, 14)
    => close

val_slope = f_slope(slope_src, slope_period)
slope_long = (val_slope > 0) and (val_slope[1] <= 0)
slope_short = (val_slope < 0) and (val_slope[1] >= 0)

// ============================================================
// 4. PLOTTING
// ============================================================

zone_color = is_buy_zone ? color.new(color.green, 85) : is_sell_zone ? color.new(color.red, 85) : na
bgcolor(zone_color, title="Trading Zones")

if bull_div
    label.new(bar_index - piv_lb_r, low[piv_lb_r], "Bull", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)

if bear_div
    label.new(bar_index - piv_lb_r, high[piv_lb_r], "Bear", color=color.red, textcolor=color.white, style=label.style_label_down, size=size.small)

plotshape(slope_long, title="Slope Long", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small)
plotshape(slope_short, title="Slope Short", style=shape.triangledown, location=location.abovebar, color=color.orange, size=size.small)

var table info_tbl = table.new(position.top_right, 2, 4, border_width = 1)
if barstate.islast
    table.cell(info_tbl, 0, 0, "Zone", text_color=color.white, bgcolor=color.gray)
    table.cell(info_tbl, 1, 0, is_buy_zone ? "BUY" : is_sell_zone ? "SELL" : "NEUTRAL", bgcolor=is_buy_zone ? color.green : is_sell_zone ? color.red : color.gray)
    
    table.cell(info_tbl, 0, 1, "Slope", text_color=color.white, bgcolor=color.gray)
    table.cell(info_tbl, 1, 1, str.tostring(val_slope, "#.####"), bgcolor=val_slope > 0 ? color.green : color.red)
















    ---------------------------------------------------------------

    //@version=5
strategy("MCG + HMA + ZLEMA + UT Bot Strategy", overlay=true, margin_long=100, margin_short=100, pyramiding=1, initial_capital=100000)

// === Inputs ===
hma_fast     = input.int(5,  "HMA Fast")
hma_slow     = input.int(14, "HMA Slow")
mcg_fast     = input.int(5,  "MCG Fast")
mcg_slow     = input.int(14, "MCG Slow")
zlema_fast   = input.int(5,  "ZLEMA Fast")
zlema_slow   = input.int(14, "ZLEMA Slow")
adx_len      = input.int(14, "ADX Length")

// UT Bot Inputs
a = input.float(1.0,   "UTBot Sensitivity (a)")
c = input.int(10,      "ATR Period (c)")
h = input.bool(false,  "Signals from Heikin Ashi Candles?")

// === Hull Moving Average ===
hma(src, length) =>
    wma1 = ta.wma(src, math.round(length / 2))
    wma2 = ta.wma(src, length)
    rawHma = 2 * wma1 - wma2
    ta.wma(rawHma, math.round(math.sqrt(length)))

hma5  = hma(close, hma_fast)
hma14 = hma(close, hma_slow)

// === McGinley Dynamic ===
mcginley(src, length) =>
    m = 0.6
    mcg = 0.0
    mcg := na(mcg[1]) ? src : mcg[1] + (src - mcg[1]) / (length * m * (src / mcg[1]) * (src / mcg[1]))
    mcg

mcg5  = mcginley(close, mcg_fast)
mcg14 = mcginley(close, mcg_slow)

// === ZLEMA (Zero Lag EMA) ===
zlema(src, length) =>
    ema1 = ta.ema(src, length)
    ema2 = ta.ema(ema1, length)
    d = ema1 - ema2
    ema1 + d

zlema5  = zlema(close, zlema_fast)
zlema14 = zlema(close, zlema_slow)

// === Previous values ===
hmafast_prev    = hma5[1]
hmaslow_prev    = hma14[1]
mcgslow_prev    = mcg14[1]
zlemaslow_prev  = zlema14[1]

// === ADX (Flat Market Filter) ===
adxLen = input.int(14, "ADX Length")

// Step 1: Calculate directional movements
upMove   = ta.change(high)
downMove = -ta.change(low)

plusDM  = (upMove > downMove and upMove > 0)  ? upMove  : 0.0
minusDM = (downMove > upMove and downMove > 0) ? downMove : 0.0

// Step 2: Calculate True Range
tr = ta.rma(ta.tr, adxLen)

// Step 3: Smoothed DM
plusDI  = 100 * ta.rma(plusDM, adxLen) / tr
minusDI = 100 * ta.rma(minusDM, adxLen) / tr

// Step 4: DX & ADX
dx  = 100 * math.abs(plusDI - minusDI) / (plusDI + minusDI)
adx = ta.rma(dx, adxLen)

// // Plots
// plot(adx,     color=color.orange, title="ADX")
// plot(plusDI,  color=color.green,  title="+DI")
// plot(minusDI, color=color.red,    title="-DI")
flat_market = adx < 20

// === Entry Conditions ===
call_entry = (hmafast_prev > hmaslow_prev) and (hmafast_prev >= hmaslow_prev) and 
             (mcg14 > hma5) and (mcg14 > mcgslow_prev) and 
             (zlema14 < mcg14) and (zlemaslow_prev <= zlema14) and 
             not flat_market

put_entry = (hma5 < hmaslow_prev) and (hmafast_prev <= hmaslow_prev) and (mcg14 < hma5) and (mcg14 < mcgslow_prev) and        (zlema14 > mcg14) and (zlemaslow_prev >= zlema14) and             not flat_market

// === Exit Conditions ===
call_exit = hma5 < hma14
put_exit  = hma5 > hma14

// === Strategy Execution ===
if call_entry
    strategy.entry("CALL", strategy.long)
if put_entry
    strategy.entry("PUT", strategy.short)

if call_exit
    strategy.close("CALL")
if put_exit
    strategy.close("PUT")

// === Plotting Indicators ===
plot(hma5,   "HMA5",   color=color.orange)
plot(hma14,  "HMA14",  color=color.blue)
plot(mcg5,   "MCG5",   color=color.green)
plot(mcg14,  "MCG14",  color=color.red)
plot(zlema5, "ZLEMA5", color=color.purple)
plot(zlema14,"ZLEMA14",color=color.purple)

// === UT BOT Logic ===
src = h ? request.security(syminfo.tickerid, timeframe.period, (open + high + low + close) / 4) : close
xATR  = ta.atr(c)
nLoss = a * xATR

var float xATRTrailingStop = na
float prev = nz(xATRTrailingStop[1], 0.0)

xATRTrailingStop := (src > prev and src[1] > prev) ? math.max(prev, src - nLoss) :                     (src < prev and src[1] < prev) ? math.min(prev, src + nLoss) :                     (src > prev ? src - nLoss : src + nLoss)
// position state
var int pos = 0
pos :=  src[1] < prev and src > prev ?  1 :          src[1] > prev and src < prev ? -1 :          nz(pos[1], 0)

// signals
ema1  = ta.ema(src, 1)
above = ta.crossover(ema1, xATRTrailingStop)
below = ta.crossover(xATRTrailingStop, ema1)

buy  = (src > xATRTrailingStop) and above
sell = (src < xATRTrailingStop) and below

plotshape(buy,  title="Buy",  text="Buy",  style=shape.labelup,   location=location.belowbar, color=color.green, textcolor=color.white, size=size.tiny)
plotshape(sell, title="Sell", text="Sell", style=shape.labeldown, location=location.abovebar, color=color.red,   textcolor=color.white, size=size.tiny)
barcolor(src > xATRTrailingStop ? color.green : src < xATRTrailingStop ? color.red : na)

alertcondition(buy,  "UT Long",  "UT Long")
alertcondition(sell, "UT Short", "UT Short")

